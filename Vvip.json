`);
console.log("\x1b[41m\x1b[37m%s\x1b[0m", " [ XDEV OMNI-GUARD : AUTO-NUKE & AUTO-REVIVE ] \n");

telegram(`
<blockquote>ūüõ°ÔłŹ <b>XDEV OMNI-GUARD AKTIF</b> ‚úÖ
‚äõ <b>Tugas 1:</b> Pembasmi Abuser (Anti-Kebal)
‚äõ <b>Tugas 2:</b> Pembersih Log Docker (Anti-Penuh)
